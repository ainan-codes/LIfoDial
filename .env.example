# ═══ DATABASE (Optional — defaults to local SQLite) ═══
# Get from supabase.com → Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# If left empty, falls back to local SQLite (development only)
DATABASE_URL=sqlite+aiosqlite:///./lifodial.db

# ═══ REQUIRED — Get from aistudio.google.com ═══
GEMINI_API_KEY=

# ═══ REQUIRED for voice calls — cloud.livekit.io ═══
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ═══ Sarvam AI (STT + TTS) ═══
SARVAM_API_KEY=

# ═══ OPTIONAL — Add when going live ═══
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══ OPTIONAL — Real HIS (mock works without) ═══
OXZYGEN_BASE_URL=
OXZYGEN_API_KEY=

# ═══ OPTIONAL — Real phone numbers ═══
VOBIZ_ACCOUNT_SID=
VOBIZ_AUTH_TOKEN=
VOBIZ_SIP_DOMAIN=

# ═══ Notifications ═══
FRONTEND_URL=http://localhost:5173
GOOGLE_SHEETS_WEBHOOK_URL=

# ═══ App / Auth ═══
ENVIRONMENT=development
# SECRET_KEY signs JWTs AND derives the provider-key encryption key.
# In production it MUST be a strong, unique value (>=32 chars) or the app
# refuses to boot. Generate one with:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=dev_only_secret_change_me_in_production_0123456789

# Platform-owner (superadmin) login. NEVER hardcode these in the frontend.
# If SUPERADMIN_PASSWORD is empty, superadmin login is disabled.
SUPERADMIN_EMAIL=admin@lifodial.com
SUPERADMIN_PASSWORD=
