# Dockerfile.agent — Pipecat voice agent worker
# Deployable as a Render web service (free tier ok — the worker binds its HTTP
# health server to $PORT; see backend/agent/__main__.py), a Render background
# worker (paid), a VPS, or locally.
FROM python:3.11-slim

WORKDIR /app

# System dependencies required by Pipecat:
#   libsndfile1 → Silero VAD / soundfile audio I/O
#   ffmpeg      → Audio format conversion
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsndfile1 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Install base + agent requirements in ONE pip pass so the resolver sees the
# full set together (requirements.agent.txt starts with `-r requirements.txt`).
# A two-phase install resolved them separately and hit ResolutionImpossible
# (e.g. base httpx pin vs pipecat's google-genai httpx>=0.28.1).
COPY requirements.txt requirements.agent.txt ./
RUN pip install --no-cache-dir -r requirements.agent.txt

COPY backend/ ./backend/

# Pipecat LiveKit agent worker entrypoint. `backend.agent` (its __main__) binds
# the health server to $PORT and runs the loud-fatal preflight.
CMD ["python", "-m", "backend.agent", "start"]
